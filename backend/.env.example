# HOA Management System — Backend Environment Variables
# Copy this file to .env and fill in your values

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database (AWS RDS PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=<your-db-password>
DB_NAME=hoa_system

# Redis (AWS ElastiCache)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (RS256 — generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem)
# Paste single-line PEM with literal \n between lines
JWT_PRIVATE_KEY=<rs256-private-key-pem>
JWT_PUBLIC_KEY=<rs256-public-key-pem>

# AWS
AWS_REGION=ap-southeast-1
AWS_S3_UPLOADS_BUCKET=<hoa-uploads-dev-bucket-name>
AWS_SES_FROM_EMAIL=<verified-ses-sender-email>

# Maya Business API (GCash payments)
MAYA_PUBLIC_KEY=<maya-api-public-key>
MAYA_SECRET_KEY=<maya-api-secret-key>
MAYA_WEBHOOK_SECRET=<maya-webhook-hmac-secret>

# Google Drive OAuth 2.0 (document repository)
GOOGLE_DRIVE_CLIENT_ID=<google-oauth-client-id>
GOOGLE_DRIVE_CLIENT_SECRET=<google-oauth-client-secret>
GOOGLE_DRIVE_TOKENS={}

# Firebase Cloud Messaging (push notifications)
# Paste the full service account JSON as a single line
FCM_SERVER_KEY=<firebase-service-account-json>

# Twilio (SMS alerts)
TWILIO_ACCOUNT_SID=<twilio-account-sid>
TWILIO_AUTH_TOKEN=<twilio-auth-token>
TWILIO_FROM_NUMBER=<twilio-phone-number>

# QR Code HMAC signing (visitor passes)
QR_HMAC_SECRET=<random-32-character-secret>
