# HOA Management System — Backend Environment Variables
# Copy this file to .env and fill in your values

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# JWT (RS256 — generate with openssl)
JWT_PRIVATE_KEY=<rs256-private-key-pem>
JWT_PUBLIC_KEY=<rs256-public-key-pem>

# ─────────────────────────────────────────────
# FREE SERVICES
# ─────────────────────────────────────────────

# Gmail SMTP (replaces AWS SES — FREE)
# Setup: Google Account → Security → App Passwords → Generate
GMAIL_USER=<your-gmail-address>
GMAIL_APP_PASSWORD=<16-char-app-password>
GMAIL_FROM="HOA Management <your-gmail-address>"

# Cloudinary (replaces AWS S3 — FREE 10GB)
# Setup: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# Railway PostgreSQL (replaces AWS RDS — FREE)
# Auto-provided by Railway when you add PostgreSQL plugin
DB_HOST=<railway-postgres-host>
DB_PORT=5432
DB_USERNAME=<railway-postgres-user>
DB_PASSWORD=<railway-postgres-password>
DB_NAME=<railway-postgres-db>

# Upstash Redis (replaces AWS ElastiCache — FREE 10K commands/day)
# Setup: https://upstash.com → Create Redis database → Copy Redis URL
REDIS_URL=rediss://<upstash-redis-url>

# PayMongo (replaces Maya Business API — FREE to register, ~2.5% per transaction)
# Setup: https://dashboard.paymongo.com → Developers → API Keys
PAYMONGO_PUBLIC_KEY=pk_test_<your-public-key>
PAYMONGO_SECRET_KEY=sk_test_<your-secret-key>
PAYMONGO_WEBHOOK_SECRET=<webhook-secret-from-paymongo-dashboard>

# Google Drive OAuth 2.0 (FREE)
GOOGLE_DRIVE_CLIENT_ID=<google-oauth-client-id>
GOOGLE_DRIVE_CLIENT_SECRET=<google-oauth-client-secret>
GOOGLE_DRIVE_TOKENS={}

# Firebase Cloud Messaging — FCM (FREE)
# Paste the full service account JSON as a single line
FCM_SERVER_KEY=<firebase-service-account-json>

# QR Code HMAC signing (visitor passes)
QR_HMAC_SECRET=<random-32-character-secret>
